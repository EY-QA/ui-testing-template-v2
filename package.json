{
  "name": "templateprojectjavascript",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "seed": "playwright test seed.spec.ts",
    "postinstall": "npx playwright install",
    "test": "cucumber-js --format \"json:report.json\"",
    "test:ui": "cucumber-js -p ui",
    "test:all": "npm run test:chrome && npm run test:firefox && npm run test:webkit",
    "test:chrome": "cross-env PW_BROWSER=chromium PW_BROWSER_CHANNEL=chrome npx cucumber-js",
    "test:firefox": "cross-env PW_BROWSER=firefox npx cucumber-js",
    "test:webkit": "cross-env PW_BROWSER=webkit npx cucumber-js",
    "report": "node scripts/open-report.js",
    "smoke": "cross-env TAGS=@smoke cucumber-js",
    "regression": "cross-env TAGS='not @wip' cucumber-js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.6.0",
    "@cucumber/html-formatter": "^20.4.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^6.0.0",
    "dotenv": "^16.4.5",
    "open": "^9.1.0",
    "playwright": "^1.58.2"
  }
}
